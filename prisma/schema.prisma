generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

enum ProjectStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  AGRICULTURAL
  INDUSTRIAL
  OTHER
}

enum CompensationStatus {
  DRAFT
  NOT_YET_PAID
  COUNCIL_REVIEW
  FINANCE_PROCESSING
  PAID
  FAILED
  CANCELLED
}

enum CouncilDecision {
  PENDING
  APPROVED
  REVISION_NEEDED
}

enum ComplaintStatus {
  SUBMITTED
  UNDER_REVIEW
  RESOLVED
  REJECTED
}

enum ComplaintCategory {
  LAND_ISSUE
  VALUATION_ISSUE
  OWNERSHIP_ISSUE
  PAYMENT_ISSUE
  OTHER
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(VIEWER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdProjects   Project[]        @relation("CreatedProjects")
  assignedProjects  Project[]        @relation("AssignedProjects")
  recordedReviews   CouncilReview[]
  resolvedComplaints Complaint[]     @relation("ResolvedComplaints")
  recordedPayments  Payment[]        @relation("RecordedPayments")
}

model Project {
  id               String        @id @default(cuid())
  name             String
  location         String
  budget           Float
  deadline         DateTime
  description      String?
  status           ProjectStatus @default(PENDING)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  createdById      String
  createdBy        User          @relation("CreatedProjects", fields: [createdById], references: [id])

  assignedEditorId String?
  assignedEditor   User?         @relation("AssignedProjects", fields: [assignedEditorId], references: [id])

  paps Pap[]
  complaints Complaint[]
  payments Payment[]
}

model Pap {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  // Owner Information
  ownerName          String
  ownerId            String
  ownerPhone         String?
  ownerEmail         String?
  civilStatus        String? // Single, Married, Divorced, Widowed

  // Beneficiary Information
  beneficiaryName    String
  beneficiaryId      String
  beneficiaryPhone   String?
  beneficiaryEmail   String?
  relationship       String? // Relationship to owner

  // Land Information
  affectedUpi        String   // Unique Parcel Identifier
  affectedArea       Float    // Square meters
  propertyType       PropertyType @default(RESIDENTIAL)
  sector             String
  cell               String
  village            String
  landRegistration   String?  // Land registration info
  landDescription    String?

  // Compensation & Status
  compensationStatus CompensationStatus @default(DRAFT)
  compensationAmount Float?   // Valuation amount
  valuationDate      DateTime?
  valuationComment   String?

  // Approval Signatures
  ownerSigned        Boolean  @default(false)
  ownerSignedDate    DateTime?
  cellSigned         Boolean  @default(false)
  cellSignedDate     DateTime?
  sectorSigned       Boolean  @default(false)
  sectorSignedDate   DateTime?

  // Verification tracking
  landVerified       Boolean  @default(false)
  landVerifiedBy     String?
  landVerifiedDate   DateTime?
  landTitleVerified  Boolean  @default(false)
  landTitleVerifiedBy String?
  landTitleVerifiedDate DateTime?
  idVerified         Boolean  @default(false)
  idVerifiedBy       String?
  idVerifiedDate     DateTime?

  // Council Reviews
  councilReviews CouncilReview[]

  // Complaints
  complaints Complaint[]

  // Payments
  payments Payment[]

  // Payment Info (basic, full in payments module)
  bankName           String?
  accountNumber      String?
  paymentCode        String?
  paidAmount         Float?
  paidDate           DateTime?
}

model CouncilReview {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  papId String
  pap   Pap @relation(fields: [papId], references: [id])

  // Review Information
  reviewDate    DateTime       @default(now())
  reviewerName  String
  decision      CouncilDecision @default(PENDING)
  feedback      String?
  approvedAmount Float?

  // Who recorded this review
  recordedById String
  recordedBy   User   @relation(fields: [recordedById], references: [id])
}

model Complaint {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  papId     String
  pap       Pap      @relation(fields: [papId], references: [id])

  projectId String
  project   Project  @relation(fields: [projectId], references: [id])

  // Complaint Information
  category    ComplaintCategory
  description String
  status      ComplaintStatus @default(SUBMITTED)
  resolution  String?

  // Resolution tracking
  resolvedAt   DateTime?
  resolvedById String?
  resolvedBy   User?    @relation("ResolvedComplaints", fields: [resolvedById], references: [id])

  // Appeal linking (self-relation)
  parentComplaintId String?
  parentComplaint   Complaint? @relation("AppealChain", fields: [parentComplaintId], references: [id])
  childComplaints   Complaint[] @relation("AppealChain")
}

model Payment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  papId     String
  pap       Pap      @relation(fields: [papId], references: [id])

  projectId String
  project   Project  @relation(fields: [projectId], references: [id])

  // Beneficiary Information (snapshot at time of payment)
  beneficiaryName    String
  beneficiaryId      String
  beneficiaryPhone   String?
  beneficiaryEmail   String?

  // Bank & Payment Information
  bankName           String
  accountNumber      String
  amount             Float
  paymentCode        String?
  paidDate           DateTime?
  notes              String?

  // Status
  status             PaymentStatus @default(PENDING)

  // Who recorded this payment
  recordedById String
  recordedBy   User   @relation("RecordedPayments", fields: [recordedById], references: [id])
}

